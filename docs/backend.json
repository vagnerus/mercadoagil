
{
  "entities": {
    "PlatformUser": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PlatformUser",
      "type": "object",
      "description": "Represents a user of the platform, either a Super Admin managing the overall platform or a Merchant Admin/Staff managing a specific store. Passwords are handled by an external authentication system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the PlatformUser entity."
        },
        "email": {
          "type": "string",
          "description": "The user's email address, used for login and communication.",
          "format": "email"
        },
        "firstName": {
          "type": "string",
          "description": "The first name of the user."
        },
        "lastName": {
          "type": "string",
          "description": "The last name of the user."
        },
        "role": {
          "type": "string",
          "description": "The role of the user within the platform (e.g., 'SUPER_ADMIN', 'MERCHANT_ADMIN', 'MERCHANT_STAFF')."
        },
        "merchantId": {
          "type": "string",
          "description": "Reference to the Merchant this user is associated with."
        },
        "merchantSlug": {
          "type": "string",
          "description": "URL slug of the associated merchant."
        },
        "isActive": {
          "type": "boolean",
          "description": "Indicates if the user account is active."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "role",
        "isActive"
      ]
    },
    "Merchant": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Merchant",
      "type": "object",
      "description": "Represents a single store or business ('lojista') operating on the e-commerce platform.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "slug": {
          "type": "string"
        },
        "segment": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "slug",
        "segment"
      ]
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "type": "object",
      "description": "Chamados de suporte abertos por lojistas via chat para o Master Admin.",
      "properties": {
        "id": { "type": "string" },
        "merchantId": { "type": "string" },
        "merchantName": { "type": "string" },
        "userEmail": { "type": "string" },
        "lastMessage": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "in_progress", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["merchantId", "merchantName", "userEmail", "status"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/platformUsers/{platformUserId}",
        "definition": {
          "entityName": "PlatformUser",
          "schema": { "$ref": "#/backend/entities/PlatformUser" },
          "description": "Perfis de usuários da plataforma."
        }
      },
      {
        "path": "/merchants/{merchantId}",
        "definition": {
          "entityName": "Merchant",
          "schema": { "$ref": "#/backend/entities/Merchant" },
          "description": "Instâncias de lojas."
        }
      },
      {
        "path": "/supportTickets/{ticketId}",
        "definition": {
          "entityName": "SupportTicket",
          "schema": { "$ref": "#/backend/entities/SupportTicket" },
          "description": "Tickets de suporte para o Master Admin."
        }
      }
    ]
  }
}
