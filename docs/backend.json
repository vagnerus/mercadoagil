
{
  "entities": {
    "PlatformUser": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PlatformUser",
      "type": "object",
      "description": "Represents a user of the platform.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string" },
        "merchantId": { "type": "string" },
        "merchantSlug": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role", "isActive"]
    },
    "Merchant": {
      "title": "Merchant",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "segment": { "type": "string" },
        "status": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "slug", "segment"]
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "merchantId": { "type": "string" },
        "merchantName": { "type": "string" },
        "userEmail": { "type": "string" },
        "subject": { "type": "string" },
        "reason": { "type": "string" },
        "urgency": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["merchantId", "merchantName", "userEmail", "status", "subject", "urgency"]
    },
    "CustomerReview": {
      "title": "CustomerReview",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "merchantId": { "type": "string" },
        "customerName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "sentiment": { "type": "string" },
        "aiResponse": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "EmployeeShift": {
      "title": "EmployeeShift",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "staffId": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "status": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/platformUsers/{platformUserId}",
        "definition": {
          "entityName": "PlatformUser",
          "schema": { "$ref": "#/backend/entities/PlatformUser" },
          "description": "Perfis de usuários."
        }
      },
      {
        "path": "/merchants/{merchantId}",
        "definition": {
          "entityName": "Merchant",
          "schema": { "$ref": "#/backend/entities/Merchant" },
          "description": "Lojas lojistas."
        }
      },
      {
        "path": "/supportTickets/{ticketId}",
        "definition": {
          "entityName": "SupportTicket",
          "schema": { "$ref": "#/backend/entities/SupportTicket" },
          "description": "Tickets de suporte."
        }
      },
      {
        "path": "/merchants/{merchantId}/reviews/{reviewId}",
        "definition": {
          "entityName": "CustomerReview",
          "schema": { "$ref": "#/backend/entities/CustomerReview" },
          "description": "Avaliações de clientes."
        }
      },
      {
        "path": "/merchants/{merchantId}/shifts/{shiftId}",
        "definition": {
          "entityName": "EmployeeShift",
          "schema": { "$ref": "#/backend/entities/EmployeeShift" },
          "description": "Escalas de trabalho."
        }
      }
    ]
  }
}
