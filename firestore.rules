/**
 * Firestore Security Rules - Mercado Ágil Enterprise
 * 
 * CORE PHILOSOPHY:
 * Proteção multi-tenant com fallback para Super Admin mestre.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Helper para verificar se o usuário é o Super Admin mestre por e-mail
    function isMasterAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'vagneroliveira.us@gmail.com' ||
        request.auth.token.email == 'admin@mercadoagil.com'
      );
    }

    function getPlatformUser() {
      return isSignedIn() ? get(/databases/$(database)/documents/platformUsers/$(request.auth.uid)).data : null;
    }

    function isSuperAdmin() {
      return isMasterAdmin() || (isSignedIn() && getPlatformUser() != null && getPlatformUser().role == 'SUPER_ADMIN');
    }

    // --- COLLECTION RULES ---

    match /platformUsers/{platformUserId} {
      // Permitir leitura e listagem para que o sistema de login identifique o cargo do usuário
      allow get, list: if isSignedIn();
      // Criar e atualizar permitido para o próprio usuário ou master
      allow create, update: if isSignedIn();
      allow delete: if isSuperAdmin();
    }

    match /plans/{planId} {
      allow get, list: if true;
      allow write: if isSuperAdmin();
    }

    match /merchants/{merchantId} {
      allow get, list: if true; 
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.platformUserId == request.auth.uid || isSuperAdmin());
      allow delete: if isSuperAdmin();

      // Subcoleções de cada lojista (Agenda, Pedidos, etc)
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /auditLogs/{auditLogId} {
      allow read, write: if isSuperAdmin();
    }
  }
}