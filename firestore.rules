
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Helper para verificar se o usuário é o Super Admin mestre por e-mail
    function isMasterAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'vagneroliveira.us@gmail.com' ||
        request.auth.token.email == 'admin@mercadoagil.com'
      );
    }

    function getPlatformUser() {
      return isSignedIn() ? get(/databases/$(database)/documents/platformUsers/$(request.auth.uid)).data : null;
    }

    function isSuperAdmin() {
      return isMasterAdmin() || (isSignedIn() && getPlatformUser() != null && getPlatformUser().role == 'SUPER_ADMIN');
    }

    // --- COLLECTION RULES ---

    match /platformUsers/{platformUserId} {
      // Permitir leitura e escrita para o próprio usuário gerenciar seu perfil
      allow get, write: if isSignedIn() && (request.auth.uid == platformUserId || isMasterAdmin());
      // Permitir listagem via query de e-mail para o fluxo de login
      allow list: if isSignedIn();
    }

    match /merchants/{merchantId} {
      // Permitir que usuários logados criem suas próprias lojas
      allow create: if isSignedIn();
      // Permitir leitura pública para a vitrine
      allow get, list: if true; 
      // Permitir atualização para o dono da loja ou master
      allow update: if isSignedIn() && (resource.data.platformUserId == request.auth.uid || isMasterAdmin());
      allow delete: if isMasterAdmin();

      // Subcoleções de cada lojista (Agenda, Pedidos, etc)
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /plans/{planId} {
      allow get, list: if true;
      allow write: if isSuperAdmin();
    }

    match /auditLogs/{auditLogId} {
      allow read, write: if isSuperAdmin();
    }
  }
}
