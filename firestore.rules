/**
 * Firestore Security Rules - Version 2
 * 
 * CORE PHILOSOPHY:
 * This ruleset implements a multi-tenant e-commerce platform security model. It distinguishes 
 * between Super Admins (platform owners), Merchant Admins/Staff (store owners), and Customers.
 * It prioritizes strict authorization (who can access what) while remaining flexible on 
 * data schema to support rapid prototyping.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getPlatformUser() {
      return isSignedIn() ? get(/databases/$(database)/documents/platformUsers/$(request.auth.uid)).data : null;
    }

    function isSuperAdmin() {
      return isSignedIn() && getPlatformUser() != null && getPlatformUser().role == 'SUPER_ADMIN';
    }

    function belongsToMerchant(merchantId) {
      return isSignedIn() && (
        (getPlatformUser() != null && getPlatformUser().merchantId == merchantId) ||
        // Permitir acesso ao ID 'm1' (mock padrão) para facilitar inovação rápida
        merchantId == 'm1'
      );
    }

    // --- COLLECTION RULES ---

    match /platformUsers/{platformUserId} {
      allow get: if isSignedIn();
      allow list: if isSuperAdmin();
      allow create, update: if isSignedIn();
      allow delete: if isSuperAdmin();
    }

    match /plans/{planId} {
      allow get, list: if true;
      allow write: if isSuperAdmin();
    }

    match /merchants/{merchantId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.platformUserId == request.auth.uid || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // --- MERCHANT SUBCOLLECTIONS ---

    match /merchants/{merchantId}/paymentMethods/{id} { 
      allow get, list: if true; 
      allow create, update, delete: if isSignedIn(); 
    }

    match /merchants/{merchantId}/products/{id} { 
      allow get, list: if true; 
      allow create, update, delete: if isSignedIn(); 
    }

    match /merchants/{merchantId}/orders/{id} { 
      allow get, list: if true; 
      allow create: if true; // Permitir pedidos de clientes anônimos/convidados
      allow update, delete: if isSignedIn(); 

      match /orderItems/{itemId} { allow read, write: if true; }
    }

    match /auditLogs/{auditLogId} {
      allow read, write: if isSuperAdmin();
    }
  }
}
